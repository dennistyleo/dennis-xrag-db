<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AICHIP XRAG · Multi-Axiom Analysis</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/static/aichip-logo.png">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Socket.IO -->
    <script src="https://cdn.socket.io/4.5.4/socket.io.min.js"></script>
    
    <style>
        /* 純黑背景 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: #000000;
            color: #FFFFFF;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.5;
            padding: 2rem;
        }
        
        .container {
            max-width: 1600px;
            margin: 0 auto;
        }
        
        /* 導航列 */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 2rem;
            border-bottom: 1px solid #222;
            margin-bottom: 2rem;
        }
        
        .logo-area {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .logo-img {
            height: 60px;
            width: auto;
            object-fit: contain;
        }
        
        .logo-text {
            font-size: 1.25rem;
            font-weight: 400;
            color: #888;
            letter-spacing: 0.5px;
        }
        
        .status-badge {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: #111;
            padding: 0.5rem 1rem;
            border-radius: 40px;
            border: 1px solid #222;
        }
        
        .status-dot {
            width: 10px;
            height: 10px;
            background: #00ff00;
            border-radius: 50%;
            box-shadow: 0 0 10px #00ff00;
        }
        
        .refresh-btn {
            background: #111;
            border: 1px solid #333;
            color: #fff;
            padding: 0.5rem 1.2rem;
            border-radius: 6px;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .refresh-btn:hover {
            background: #222;
            border-color: #555;
        }
        
        /* 統計卡片 */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        
        .stat-card {
            background: #0a0a0a;
            border: 1px solid #222;
            border-radius: 12px;
            padding: 1.5rem;
        }
        
        .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            color: #888;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .stat-number {
            font-size: 3rem;
            font-weight: 600;
            color: #fff;
            line-height: 1;
            margin-bottom: 0.5rem;
        }
        
        .stat-footer {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            color: #666;
        }
        
        .trend-up {
            color: #00ff00;
        }
        
        /* 面板 */
        .panel {
            background: #0a0a0a;
            border: 1px solid #222;
            border-radius: 12px;
            padding: 1.5rem;
            height: fit-content;
        }
        
        .panel-title {
            font-size: 1.1rem;
            font-weight: 500;
            color: #fff;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        /* 表單元素 */
        .form-group {
            margin-bottom: 1.25rem;
        }
        
        .form-label {
            display: block;
            color: #aaa;
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }
        
        .form-select, .form-input {
            width: 100%;
            background: #111;
            border: 1px solid #333;
            color: #fff;
            padding: 0.75rem;
            border-radius: 6px;
        }
        
        .form-select option {
            background: #111;
            color: #fff;
        }
        
        .form-select optgroup {
            background: #111;
            color: #aaa;
            font-weight: 600;
        }
        
        .param-input {
            background: #1a1a1a;
            border: 1px solid #333;
            color: #fff;
            padding: 0.5rem;
            border-radius: 4px;
            width: 120px;
        }
        
        .param-row {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 0.75rem;
            padding: 0.5rem;
            background: #0f0f0f;
            border-radius: 6px;
        }
        
        .param-label {
            width: 140px;
            color: #ccc;
            font-size: 0.9rem;
        }
        
        .param-unit {
            color: #666;
            font-size: 0.8rem;
            margin-left: 0.5rem;
        }
        
        .formula-preview {
            background: #1a1a1a;
            border-left: 4px solid #00ff00;
            padding: 1rem;
            border-radius: 4px;
            font-family: monospace;
            font-size: 1.1rem;
            color: #0f0;
            margin: 1rem 0;
        }
        
        .submit-btn {
            width: 100%;
            background: #fff;
            color: #000;
            border: none;
            border-radius: 6px;
            padding: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: opacity 0.2s;
        }
        
        .submit-btn:hover {
            opacity: 0.9;
        }
        
        /* 雙欄佈局 */
        .row-2col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        
        /* 三欄佈局 */
        .row-3col {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        
        /* 分類計數徽章 */
        .category-badge {
            background: #222;
            color: #aaa;
            font-size: 0.7rem;
            padding: 0.2rem 0.5rem;
            border-radius: 12px;
            margin-left: 0.5rem;
        }
        
        /* 多公理分析樣式 */
        .selected-axioms {
            margin-bottom: 1rem;
            max-height: 300px;
            overflow-y: auto;
        }
        
        .selected-axiom-item {
            background: #1a1a1a;
            border-left: 4px solid #00ff00;
            padding: 1rem;
            margin-bottom: 0.75rem;
            border-radius: 6px;
        }
        
        .domain-badge {
            background: #333;
            color: #00ff00;
            font-size: 0.7rem;
            padding: 0.2rem 0.5rem;
            border-radius: 12px;
            margin-left: 0.5rem;
        }
        
        .add-axiom-btn {
            width: 100%;
            background: #222;
            border: 1px dashed #444;
            color: #888;
            padding: 1rem;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 1rem;
        }
        
        .add-axiom-btn:hover {
            background: #2a2a2a;
            border-color: #00ff00;
            color: #00ff00;
        }
        
        /* Modal 樣式 */
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            z-index: 1000;
            display: none;
        }
        
        .modal-content {
            background: #1a1a1a;
            width: 500px;
            margin: 100px auto;
            padding: 2rem;
            border-radius: 12px;
            border: 1px solid #333;
            max-height: 80vh;
            overflow-y: auto;
        }
        
        .modal-buttons {
            display: flex;
            gap: 1rem;
            margin-top: 1.5rem;
        }
        
        .modal-buttons button {
            flex: 1;
            padding: 0.75rem;
            border-radius: 6px;
            cursor: pointer;
        }
        
        .modal-add-btn {
            background: #00ff00;
            color: #000;
            border: none;
            font-weight: bold;
        }
        
        .modal-cancel-btn {
            background: #333;
            color: #fff;
            border: none;
        }
        
        .shared-params, .weights-section, .results-section {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid #333;
        }
        
        .shared-param-row {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 0.75rem;
            padding: 0.5rem;
            background: #0f0f0f;
            border-radius: 6px;
        }
        
        .shared-param-input {
            background: #222;
            border: 1px solid #444;
            color: #fff;
            padding: 0.4rem;
            width: 100px;
            border-radius: 4px;
        }
        
        .weight-slider {
            width: 200px;
            accent-color: #00ff00;
        }
        
        .result-card {
            background: #1a1a1a;
            padding: 1rem;
            border-radius: 8px;
            text-align: center;
        }
        
        .result-value {
            font-size: 1.5rem;
            font-weight: bold;
            color: #00ff00;
        }
        
        .combined-score {
            text-align: center;
            margin: 2rem 0;
            padding: 1rem;
            background: linear-gradient(135deg, #1a1a1a, #000);
            border-radius: 12px;
        }
        
        .combined-score .value {
            font-size: 3rem;
            font-weight: bold;
            color: #00ff00;
            display: block;
        }
        
        .badge-beta {
            background: #ffaa00;
            color: #000;
            font-size: 0.6rem;
            padding: 0.2rem 0.5rem;
            border-radius: 20px;
            margin-left: 0.5rem;
            text-transform: uppercase;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container">
        
        <!-- 導航列 -->
        <div class="navbar">
            <div class="logo-area">
                <img src="/static/aichip-logo.png" alt="AICHIP" class="logo-img">
                <span class="logo-text">XRAG · Multi-Axiom Engine</span>
            </div>
            <div style="display: flex; align-items: center; gap: 1.5rem;">
                <div class="status-badge">
                    <span class="status-dot"></span>
                    <span class="status-text">System Online</span>
                </div>
                <button onclick="refreshData()" class="refresh-btn">
                    <i class="fas fa-sync-alt" style="margin-right: 0.5rem;"></i>Refresh
                </button>
            </div>
        </div>
        
        <!-- 統計卡片 -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-header"><span>Total Axioms</span></div>
                <div class="stat-number" id="totalAxioms">136</div>
                <div class="stat-footer"><span class="trend-up">↑+12</span> this month</div>
            </div>
            <div class="stat-card">
                <div class="stat-header"><span>Frozen</span></div>
                <div class="stat-number" id="frozenAxioms">5</div>
                <div class="stat-footer"><span class="trend-up">↑+2</span> today</div>
            </div>
            <div class="stat-card">
                <div class="stat-header"><span>Pending</span></div>
                <div class="stat-number" id="pendingReviews">3</div>
                <div class="stat-footer"><span style="color:#ffaa00">1 high priority</span></div>
            </div>
            <div class="stat-card">
                <div class="stat-header"><span>UPASL</span></div>
                <div class="stat-number" style="font-size:2rem;">Active</div>
                <div class="stat-footer">2.3ms latency</div>
            </div>
        </div>

        <!-- 第一行：領域分佈 + 最近活動 + 待審清單 -->
        <div class="row-3col">
            <!-- 領域分佈 -->
            <div class="panel">
                <div class="panel-title">
                    <i class="fas fa-chart-pie" style="color:#888"></i> Domain Distribution
                </div>
                <canvas id="domainChart" height="200"></canvas>
            </div>
            
            <!-- 最近活動 -->
            <div class="panel">
                <div class="panel-title">
                    <i class="fas fa-history" style="color:#888"></i> Recent Activity
                </div>
                <div id="recentActivities" class="space-y-3">
                    <div class="flex items-center justify-between">
                        <span>Bearing Wear v2</span>
                        <span class="text-gray-500">2 min ago</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span>Quantum Correction</span>
                        <span class="text-gray-500">15 min ago</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span>Thermal Expansion</span>
                        <span class="text-gray-500">1 hour ago</span>
                    </div>
                </div>
            </div>
            
            <!-- 待審清單 -->
            <div class="panel">
                <div class="panel-title" style="justify-content: space-between;">
                    <span><i class="fas fa-clipboard-list" style="color:#888"></i> Pending Review</span>
                    <span style="background:#222; padding:0.2rem 0.8rem; border-radius:40px; font-size:0.8rem;" id="pendingCount">3</span>
                </div>
                <div id="pendingList" style="max-height: 200px; overflow-y: auto;">
                    <div style="background:#111; border-left:4px solid #ffaa00; padding:0.75rem; margin-bottom:0.5rem;">
                        <div>Quantum Effect Correction</div>
                        <div class="text-sm text-gray-500">quantum · 82%</div>
                    </div>
                    <div style="background:#111; border-left:4px solid #ffaa00; padding:0.75rem; margin-bottom:0.5rem;">
                        <div>High Temp Fatigue</div>
                        <div class="text-sm text-gray-500">aging · 91%</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 第二行：單公理新增 + 多公理分析 -->
        <div class="row-2col">
            <!-- 左欄：單公理新增 (原本的) -->
            <div class="panel">
                <div class="panel-title">
                    <i class="fas fa-plus-circle" style="color:#888"></i> Add Single Axiom
                </div>
                
                <div class="form-group">
                    <label class="form-label">Axiom Name</label>
                    <input type="text" id="axiomName" class="form-input" placeholder="e.g., Bearing Wear Prediction">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Domain</label>
                    <select id="axiomDomain" class="form-select" onchange="updateSubdomains()">
                        <option value="">-- Choose Domain --</option>
                        <option value="thermal">🔥 Thermal (35)</option>
                        <option value="electrical">⚡ Electrical (28)</option>
                        <option value="aging">⏳ Aging (22)</option>
                        <option value="quantum">⚛️ Quantum (15)</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Category</label>
                    <select id="axiomSubdomain" class="form-select" onchange="updateFormulaTemplates()" disabled>
                        <option value="">-- First select domain --</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Formula Template</label>
                    <select id="formulaTemplate" class="form-select" onchange="updateFormulaParameters()" disabled>
                        <option value="">-- First select category --</option>
                    </select>
                </div>
                
                <div id="parameterSection" class="form-group" style="background:#0f0f0f; padding:1rem; border-radius:8px;">
                    <div style="color:#666; text-align:center; padding:2rem;">Select a formula template</div>
                </div>
                
                <div id="formulaPreview" class="formula-preview">
                    Select a formula template
                </div>
                
                <div class="form-group">
                    <label class="form-label">Confidence: <span id="confidenceValue">95%</span></label>
                    <input type="range" id="axiomConfidence" min="0" max="1" step="0.01" value="0.95" 
                           class="w-full" style="accent-color: #00ff00;" oninput="updateConfidence()">
                </div>
                
                <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem;">
                    <input type="checkbox" id="requiresExpert" style="width:18px; height:18px;">
                    <label for="requiresExpert">Requires expert review</label>
                </div>
                
                <button onclick="submitUserFriendlyAxiom()" class="submit-btn">
                    <i class="fas fa-paper-plane mr-2"></i>Submit Axiom
                </button>
            </div>
            
            <!-- 右欄：多公理分析 (全新) -->
            <div class="panel">
                <div class="panel-title">
                    <i class="fas fa-cubes" style="color:#888"></i> 
                    Multi-Axiom Analysis
                    <span class="badge-beta">Beta</span>
                </div>
                
                <!-- 已選公理列表 -->
                <div id="selectedAxioms" class="selected-axioms">
                    <!-- 動態加入 -->
                </div>
                
                <!-- 添加公理按鈕 -->
                <button onclick="showAxiomSelector()" class="add-axiom-btn">
                    <i class="fas fa-plus"></i> Add Axiom to Analysis
                </button>
                
                <!-- 共享參數區 (自動產生) -->
                <div id="sharedParamsSection" class="shared-params" style="display:none;">
                    <h4 class="text-white font-medium mb-3">🔗 Shared Parameters</h4>
                    <p class="text-gray-400 text-sm mb-3">These parameters appear in multiple axioms</p>
                    <div id="sharedParamsList"></div>
                </div>
                
                <!-- 權重調整區 -->
                <div id="weightsSection" class="weights-section" style="display:none;">
                    <h4 class="text-white font-medium mb-3">⚖️ Axiom Weights</h4>
                    <div id="weightSliders"></div>
                </div>
                
                <!-- 分析按鈕 -->
                <button onclick="runMultiAnalysis()" class="submit-btn" id="analyzeBtn" disabled>
                    <i class="fas fa-chart-line"></i> Run Combined Analysis
                </button>
                
                <!-- 結果顯示區 -->
                <div id="multiResults" class="results-section" style="display:none;">
                    <h4 class="text-white font-medium mb-3">📊 Analysis Results</h4>
                    
                    <!-- 個別結果 (三欄) -->
                    <div id="individualResults" class="grid grid-cols-3 gap-3 mb-4"></div>
                    
                    <!-- 綜合分數 -->
                    <div class="combined-score">
                        <span class="text-gray-400">Combined Risk Score:</span>
                        <span class="value" id="combinedScore">0%</span>
                    </div>
                    
                    <!-- 靈敏度分析 -->
                    <div class="mt-4">
                        <h5 class="text-gray-300 text-sm mb-2">Parameter Sensitivity</h5>
                        <canvas id="sensitivityChart" height="150"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 公理選擇 Modal -->
    <div id="axiomSelectorModal" class="modal">
        <div class="modal-content">
            <h3 class="text-xl font-bold mb-4">Select Axiom for Multi-Analysis</h3>
            
            <div class="form-group">
                <label class="form-label">Domain</label>
                <select id="modalDomain" class="form-select" onchange="modalUpdateSubdomains()">
                    <option value="">-- Choose Domain --</option>
                    <option value="thermal">🔥 Thermal (35)</option>
                    <option value="electrical">⚡ Electrical (28)</option>
                    <option value="aging">⏳ Aging (22)</option>
                    <option value="quantum">⚛️ Quantum (15)</option>
                </select>
            </div>
            
            <div class="form-group">
                <label class="form-label">Category</label>
                <select id="modalSubdomain" class="form-select" onchange="modalUpdateTemplates()" disabled>
                    <option value="">-- First select domain --</option>
                </select>
            </div>
            
            <div class="form-group">
                <label class="form-label">Formula Template</label>
                <select id="modalTemplate" class="form-select" onchange="modalUpdateParams()" disabled>
                    <option value="">-- First select category --</option>
                </select>
            </div>
            
            <div id="modalParams" class="form-group" style="background:#0f0f0f; padding:1rem; border-radius:8px;">
                <div style="color:#666; text-align:center; padding:1rem;">Select a formula template</div>
            </div>
            
            <div class="modal-buttons">
                <button onclick="addToMultiAxiom()" class="modal-add-btn">Add to Analysis</button>
                <button onclick="closeModal()" class="modal-cancel-btn">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        // ==================== 資料定義 ====================
        const domainHierarchy = {
            thermal: {
                name: 'Thermal',
                icon: '🔥',
                subdomains: {
                    conduction: { name: 'Heat Conduction', count: 12 },
                    convection: { name: 'Convection', count: 8 },
                    radiation: { name: 'Thermal Radiation', count: 7 }
                }
            },
            electrical: {
                name: 'Electrical',
                icon: '⚡',
                subdomains: {
                    dc: { name: 'DC Circuits', count: 10 },
                    ac: { name: 'AC Circuits', count: 8 }
                }
            },
            aging: {
                name: 'Aging',
                icon: '⏳',
                subdomains: {
                    temperature: { name: 'Temperature Acceleration', count: 8 },
                    mechanical: { name: 'Mechanical Fatigue', count: 5 }
                }
            },
            quantum: {
                name: 'Quantum',
                icon: '⚛️',
                subdomains: {
                    wave: { name: 'Wave Mechanics', count: 5 },
                    uncertainty: { name: 'Uncertainty', count: 3 }
                }
            }
        };
        
        const formulaTemplates = {
            conduction: {
                fourier: {
                    name: 'Fourier\'s Law',
                    formula: 'Q = k·A·ΔT/d',
                    params: [
                        {name: 'k', label: 'Thermal Conductivity', unit: 'W/m·K', default: '237'},
                        {name: 'A', label: 'Area', unit: 'm²', default: '0.01'},
                        {name: 'ΔT', label: 'Temperature Difference', unit: 'K', default: '50'},
                        {name: 'd', label: 'Thickness', unit: 'm', default: '0.005'}
                    ],
                    output: 'Q',
                    outputUnit: 'W'
                }
            },
            temperature: {
                arrhenius: {
                    name: 'Arrhenius Model',
                    formula: 'L = L₀·exp(-Ea/(k·T))',
                    params: [
                        {name: 'L₀', label: 'Initial Life', unit: 'hours', default: '100000'},
                        {name: 'Ea', label: 'Activation Energy', unit: 'eV', default: '0.85'},
                        {name: 'T', label: 'Temperature', unit: 'K', default: '353'}
                    ],
                    output: 'L',
                    outputUnit: 'hours'
                }
            },
            dc: {
                ohm: {
                    name: 'Ohm\'s Law',
                    formula: 'V = I·R',
                    params: [
                        {name: 'I', label: 'Current', unit: 'A', default: '1'},
                        {name: 'R', label: 'Resistance', unit: 'Ω', default: '100'}
                    ],
                    output: 'V',
                    outputUnit: 'V'
                }
            }
        };

        // ==================== 多公理分析狀態 ====================
        let selectedAxioms = [];
        
        // ==================== 單公理表單函數 ====================
        function updateSubdomains() {
            const domain = document.getElementById('axiomDomain').value;
            const subdomainSelect = document.getElementById('axiomSubdomain');
            
            if (!domain) {
                subdomainSelect.innerHTML = '<option value="">-- First select domain --</option>';
                subdomainSelect.disabled = true;
                return;
            }
            
            const domainData = domainHierarchy[domain];
            if (!domainData) return;
            
            let options = '<option value="">-- Select category --</option>';
            for (const [key, sub] of Object.entries(domainData.subdomains)) {
                options += `<option value="${key}">${sub.name} (${sub.count})</option>`;
            }
            
            subdomainSelect.innerHTML = options;
            subdomainSelect.disabled = false;
            document.getElementById('formulaTemplate').disabled = true;
        }
        
        function updateFormulaTemplates() {
            const subdomain = document.getElementById('axiomSubdomain').value;
            const templateSelect = document.getElementById('formulaTemplate');
            
            if (!subdomain) {
                templateSelect.innerHTML = '<option value="">-- First select category --</option>';
                templateSelect.disabled = true;
                return;
            }
            
            const templates = formulaTemplates[subdomain];
            if (!templates) {
                templateSelect.innerHTML = '<option value="">-- No templates --</option>';
                templateSelect.disabled = false;
                return;
            }
            
            let options = '<option value="">-- Select formula --</option>';
            for (const [key, tmpl] of Object.entries(templates)) {
                options += `<option value="${key}">${tmpl.name}</option>`;
            }
            
            templateSelect.innerHTML = options;
            templateSelect.disabled = false;
        }
        
        function updateFormulaParameters() {
            const templateKey = document.getElementById('formulaTemplate').value;
            const subdomain = document.getElementById('axiomSubdomain').value;
            const paramSection = document.getElementById('parameterSection');
            const preview = document.getElementById('formulaPreview');
            
            if (!templateKey) {
                paramSection.innerHTML = '<div style="color:#666; text-align:center; padding:2rem;">Select a formula template</div>';
                preview.innerHTML = 'Select a formula template';
                return;
            }
            
            const templates = formulaTemplates[subdomain];
            const tmpl = templates[templateKey];
            if (!tmpl) return;
            
            let html = '<div style="display:grid; gap:0.75rem;">';
            tmpl.params.forEach(p => {
                html += `
                    <div class="param-row">
                        <span class="param-label">${p.label}:</span>
                        <input type="text" class="param-input" id="single_param_${p.name}" value="${p.default}">
                        <span class="param-unit">${p.unit}</span>
                    </div>
                `;
            });
            html += `</div>`;
            
            html += `
                <div style="margin-top:1rem; padding-top:0.5rem; border-top:1px solid #333;">
                    <span style="color:#888;">Output: </span>
                    <span style="color:#0f0;">${tmpl.output}</span>
                    <span style="color:#666; margin-left:0.5rem;">${tmpl.outputUnit}</span>
                </div>
            `;
            
            paramSection.innerHTML = html;
            preview.innerHTML = tmpl.formula;
        }
        
        function updateConfidence() {
            const val = document.getElementById('axiomConfidence').value;
            document.getElementById('confidenceValue').textContent = Math.round(val*100) + '%';
        }
        
        function submitUserFriendlyAxiom() {
            alert('Single axiom submitted (demo)');
        }
        
        // ==================== 多公理 Modal 函數 ====================
        function showAxiomSelector() {
            document.getElementById('axiomSelectorModal').style.display = 'block';
        }
        
        function closeModal() {
            document.getElementById('axiomSelectorModal').style.display = 'none';
        }
        
        function modalUpdateSubdomains() {
            const domain = document.getElementById('modalDomain').value;
            const subdomainSelect = document.getElementById('modalSubdomain');
            
            if (!domain) {
                subdomainSelect.innerHTML = '<option value="">-- First select domain --</option>';
                subdomainSelect.disabled = true;
                return;
            }
            
            const domainData = domainHierarchy[domain];
            let options = '<option value="">-- Select category --</option>';
            for (const [key, sub] of Object.entries(domainData.subdomains)) {
                options += `<option value="${key}">${sub.name} (${sub.count})</option>`;
            }
            
            subdomainSelect.innerHTML = options;
            subdomainSelect.disabled = false;
            document.getElementById('modalTemplate').disabled = true;
        }
        
        function modalUpdateTemplates() {
            const subdomain = document.getElementById('modalSubdomain').value;
            const templateSelect = document.getElementById('modalTemplate');
            
            if (!subdomain) {
                templateSelect.innerHTML = '<option value="">-- First select category --</option>';
                templateSelect.disabled = true;
                return;
            }
            
            const templates = formulaTemplates[subdomain];
            if (!templates) {
                templateSelect.innerHTML = '<option value="">-- No templates --</option>';
                templateSelect.disabled = false;
                return;
            }
            
            let options = '<option value="">-- Select formula --</option>';
            for (const [key, tmpl] of Object.entries(templates)) {
                options += `<option value="${key}">${tmpl.name}</option>`;
            }
            
            templateSelect.innerHTML = options;
            templateSelect.disabled = false;
        }
        
        function modalUpdateParams() {
            const templateKey = document.getElementById('modalTemplate').value;
            const subdomain = document.getElementById('modalSubdomain').value;
            const paramSection = document.getElementById('modalParams');
            
            if (!templateKey) {
                paramSection.innerHTML = '<div style="color:#666; text-align:center; padding:1rem;">Select a formula template</div>';
                return;
            }
            
            const templates = formulaTemplates[subdomain];
            const tmpl = templates[templateKey];
            if (!tmpl) return;
            
            let html = '<div style="display:grid; gap:0.75rem;">';
            tmpl.params.forEach(p => {
                html += `
                    <div class="param-row">
                        <span class="param-label">${p.label}:</span>
                        <input type="text" class="param-input modal-param" data-param="${p.name}" value="${p.default}">
                        <span class="param-unit">${p.unit}</span>
                    </div>
                `;
            });
            html += `</div>`;
            
            paramSection.innerHTML = html;
        }
        
        // ==================== 多公理核心邏輯 ====================
        function addToMultiAxiom() {
            const domain = document.getElementById('modalDomain').value;
            const subdomain = document.getElementById('modalSubdomain').value;
            const templateKey = document.getElementById('modalTemplate').value;
            
            if (!domain || !subdomain || !templateKey) {
                alert('Please select domain, category, and formula');
                return;
            }
            
            const templates = formulaTemplates[subdomain];
            const tmpl = templates[templateKey];
            
            // 收集參數
            const params = {};
            document.querySelectorAll('.modal-param').forEach(input => {
                params[input.dataset.param] = parseFloat(input.value);
            });
            
            // 建立公理實例
            const axiom = {
                id: 'axiom_' + Date.now() + '_' + Math.random().toString(36).substr(2, 4),
                name: tmpl.name,
                domain: domain,
                subdomain: subdomain,
                template: templateKey,
                params: params,
                output: tmpl.output,
                outputUnit: tmpl.outputUnit,
                formula: tmpl.formula
            };
            
            selectedAxioms.push(axiom);
            updateSelectedAxiomsList();
            detectSharedParameters();
            closeModal();
        }
        
        function updateSelectedAxiomsList() {
            const container = document.getElementById('selectedAxioms');
            container.innerHTML = '';
            
            if (selectedAxioms.length === 0) {
                container.innerHTML = '<div class="text-gray-500 text-center py-4">No axioms selected</div>';
                document.getElementById('analyzeBtn').disabled = true;
                return;
            }
            
            selectedAxioms.forEach((axiom, index) => {
                container.innerHTML += `
                    <div class="selected-axiom-item">
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            <div>
                                <strong>${axiom.name}</strong>
                                <span class="domain-badge">${axiom.domain}</span>
                            </div>
                            <button onclick="removeAxiom(${index})" class="text-red-500 hover:text-red-400">✕</button>
                        </div>
                        <div class="text-sm text-gray-400 mt-1">
                            ${Object.entries(axiom.params).map(([k,v]) => `${k}=${v}`).join(', ')}
                        </div>
                        <div class="text-xs text-gray-500 mt-1">
                            Output: ${axiom.output} (${axiom.outputUnit})
                        </div>
                    </div>
                `;
            });
            
            document.getElementById('analyzeBtn').disabled = selectedAxioms.length < 2;
        }
        
        function removeAxiom(index) {
            selectedAxioms.splice(index, 1);
            updateSelectedAxiomsList();
            detectSharedParameters();
        }
        
        function detectSharedParameters() {
            if (selectedAxioms.length < 2) {
                document.getElementById('sharedParamsSection').style.display = 'none';
                document.getElementById('weightsSection').style.display = 'none';
                return;
            }
            
            // 收集所有參數
            const allParams = [];
            selectedAxioms.forEach(axiom => {
                Object.keys(axiom.params).forEach(p => allParams.push(p));
            });
            
            // 計算每個參數出現次數
            const paramCount = {};
            allParams.forEach(p => {
                paramCount[p] = (paramCount[p] || 0) + 1;
            });
            
            // 找出共享參數 (出現次數 > 1)
            const shared = Object.entries(paramCount)
                .filter(([_, count]) => count > 1)
                .map(([param]) => param);
            
            if (shared.length === 0) {
                document.getElementById('sharedParamsSection').style.display = 'none';
            } else {
                document.getElementById('sharedParamsSection').style.display = 'block';
                
                let html = '';
                shared.forEach(param => {
                    // 找出這個參數在不同公理中的值
                    const values = [];
                    selectedAxioms.forEach(axiom => {
                        if (axiom.params[param] !== undefined) {
                            values.push(axiom.params[param]);
                        }
                    });
                    
                    // 使用平均值作為預設
                    const defaultValue = values.reduce((a,b) => a+b, 0) / values.length;
                    
                    html += `
                        <div class="shared-param-row">
                            <span class="param-label">${param}:</span>
                            <input type="text" class="shared-param-input" 
                                   data-param="${param}" 
                                   value="${defaultValue.toFixed(4)}"
                                   onchange="updateSharedParameter('${param}', this.value)">
                            <span class="param-unit">${getParamUnit(param)}</span>
                            <span class="text-gray-500 text-sm">(in ${values.length} axioms)</span>
                        </div>
                    `;
                });
                
                document.getElementById('sharedParamsList').innerHTML = html;
            }
            
            // 更新權重滑桿
            updateWeightSliders();
        }
        
        function getParamUnit(param) {
            const unitMap = {
                'k': 'W/m·K', 'A': 'm²', 'ΔT': 'K', 'd': 'm',
                'L₀': 'hours', 'Ea': 'eV', 'T': 'K',
                'I': 'A', 'R': 'Ω'
            };
            return unitMap[param] || '';
        }
        
        function updateSharedParameter(param, value) {
            const numValue = parseFloat(value);
            selectedAxioms.forEach(axiom => {
                if (axiom.params[param] !== undefined) {
                    axiom.params[param] = numValue;
                }
            });
            updateSelectedAxiomsList();
        }
        
        function updateWeightSliders() {
            if (selectedAxioms.length < 2) return;
            
            document.getElementById('weightsSection').style.display = 'block';
            
            let html = '';
            selectedAxioms.forEach((axiom, index) => {
                html += `
                    <div class="flex items-center gap-4 mb-3">
                        <span class="w-32 text-gray-300">${axiom.name}:</span>
                        <input type="range" class="weight-slider" 
                               data-index="${index}"
                               min="0" max="1" step="0.05" value="0.5"
                               oninput="updateWeight(${index}, this.value)">
                        <span class="text-green-400 font-bold w-12" id="weight_${index}">0.50</span>
                    </div>
                `;
            });
            
            document.getElementById('weightSliders').innerHTML = html;
        }
        
        function updateWeight(index, value) {
            document.getElementById(`weight_${index}`).textContent = parseFloat(value).toFixed(2);
        }
        
        function runMultiAnalysis() {
            if (selectedAxioms.length < 2) {
                alert('Please select at least 2 axioms');
                return;
            }
            
            // 收集權重
            const weights = [];
            document.querySelectorAll('.weight-slider').forEach(s => {
                weights.push(parseFloat(s.value));
            });
            
            // 收集共享參數
            const sharedParams = {};
            document.querySelectorAll('.shared-param-input').forEach(input => {
                sharedParams[input.dataset.param] = parseFloat(input.value);
            });
            
            // 模擬計算結果
            const individualResults = [];
            const values = [];
            
            selectedAxioms.forEach(axiom => {
                // 簡單的模擬計算 (實際應調用 API)
                const value = Math.random() * 100;
                values.push(value);
                individualResults.push({
                    value: value,
                    unit: axiom.outputUnit
                });
            });
            
            // 計算加權綜合分數
            let combined = 0;
            for (let i = 0; i < values.length; i++) {
                combined += values[i] * weights[i];
            }
            
            // 顯示結果
            displayMultiResults({
                individual_results: individualResults,
                combined_score: combined / 100,
                sensitivity: {
                    'Temperature': 0.45,
                    'Current': 0.32,
                    'Stress': 0.23
                }
            });
        }
        
        function displayMultiResults(data) {
            document.getElementById('multiResults').style.display = 'block';
            
            // 個別結果
            let html = '';
            data.individual_results.forEach((r, i) => {
                html += `
                    <div class="result-card">
                        <div class="text-sm text-gray-400">${selectedAxioms[i].name}</div>
                        <div class="result-value">${r.value.toFixed(1)} ${r.unit}</div>
                    </div>
                `;
            });
            document.getElementById('individualResults').innerHTML = html;
            
            // 綜合分數
            document.getElementById('combinedScore').textContent = 
                (data.combined_score * 100).toFixed(0) + '%';
            
            // 繪製靈敏度圖 (簡化版)
            const ctx = document.getElementById('sensitivityChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: Object.keys(data.sensitivity),
                    datasets: [{
                        label: 'Sensitivity',
                        data: Object.values(data.sensitivity),
                        backgroundColor: '#00ff00'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } }
                }
            });
        }
        
        // ==================== 工具函數 ====================
        function refreshData() {
            // 刷新數據 (demo)
            console.log('Refreshing data...');
        }
        
        // 初始化圖表
        const ctx = document.getElementById('domainChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Thermal', 'Electrical', 'Aging', 'Quantum', 'Others'],
                datasets: [{
                    data: [35, 28, 22, 15, 36],
                    backgroundColor: ['#5470c6', '#91cc75', '#fac858', '#ee6666', '#73c0de']
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } }
            }
        });
    </script>
</body>
</html>
